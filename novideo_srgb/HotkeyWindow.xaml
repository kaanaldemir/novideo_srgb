<Window x:Class="novideo_srgb.HotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Configure Hotkey"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12">
        <TextBlock Margin="0,0,0,8" TextWrapping="Wrap">
            Press the key you want to use, then choose any modifiers.
        </TextBlock>
        <TextBox Name="HotkeyTextBox"
                 Margin="0,0,0,8"
                 MinWidth="240"
                 IsReadOnly="True"
                 VerticalContentAlignment="Center"
                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus" />
        <WrapPanel Margin="0,0,0,12">
            <CheckBox Name="CtrlCheckBox" Margin="0,0,12,0" Content="Ctrl" />
            <CheckBox Name="AltCheckBox" Margin="0,0,12,0" Content="Alt" />
            <CheckBox Name="ShiftCheckBox" Margin="0,0,12,0" Content="Shift" />
            <CheckBox Name="WinCheckBox" Content="Win" />
        </WrapPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="75" Margin="0,0,6,0" Click="ClearButton_Click">Clear</Button>
            <Button Width="75" Margin="0,0,6,0" IsDefault="True" Click="OK_Click">OK</Button>
            <Button Width="75" IsCancel="True">Cancel</Button>
        </StackPanel>
    </StackPanel>
</Window>
