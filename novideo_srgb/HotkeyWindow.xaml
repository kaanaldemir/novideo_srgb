<Window x:Class="novideo_srgb.HotkeyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Configure Hotkey"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="12">
        <CheckBox Name="CombinedHotkeyCheckBox"
                  Margin="0,0,0,8"
                  Content="Combined hotkey for all monitors"
                  Checked="CombinedHotkeyCheckBox_Changed"
                  Unchecked="CombinedHotkeyCheckBox_Changed" />
        <ComboBox Name="MonitorComboBox"
                  Margin="0,0,0,8"
                  MinWidth="280"
                  DisplayMemberPath="Name"
                  SelectionChanged="MonitorComboBox_SelectionChanged" />
        <TextBlock Name="TargetTextBlock" Margin="0,0,0,8" TextWrapping="Wrap" />
        <TextBox Name="HotkeyTextBox"
                 Margin="0,0,0,8"
                 MinWidth="280"
                 IsReadOnly="True"
                 VerticalContentAlignment="Center"
                 PreviewKeyDown="HotkeyTextBox_PreviewKeyDown"
                 GotKeyboardFocus="HotkeyTextBox_GotKeyboardFocus" />
        <WrapPanel Margin="0,0,0,12">
            <CheckBox Name="CtrlCheckBox" Margin="0,0,12,0" Content="Ctrl" Click="ModifierCheckBox_Click" />
            <CheckBox Name="AltCheckBox" Margin="0,0,12,0" Content="Alt" Click="ModifierCheckBox_Click" />
            <CheckBox Name="ShiftCheckBox" Margin="0,0,12,0" Content="Shift" Click="ModifierCheckBox_Click" />
            <CheckBox Name="WinCheckBox" Content="Win" Click="ModifierCheckBox_Click" />
        </WrapPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="75" Margin="0,0,6,0" Click="ClearButton_Click">Clear</Button>
            <Button Width="75" Margin="0,0,6,0" IsDefault="True" Click="OK_Click">OK</Button>
            <Button Width="75" IsCancel="True">Cancel</Button>
        </StackPanel>
    </StackPanel>
</Window>
